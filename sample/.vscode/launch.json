{
  "configurations": [
    {
      "name": "Start Sample",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Sample",
      "program": "pwsh",
      "args": [
        "-NoExit",
        "-NoProfile",
        "-Command",
        "Import-Module ${workspaceFolder}/src/bin/Debug/net7.0/AutomationIoC.Sample.dll",
        "-Verbose"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ]
}
