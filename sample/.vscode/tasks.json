{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "dependsOn": ["PowerShellFocused"],
      "command": "dotnet",
      "type": "shell",
      "args": [
        "build",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "PowerShellFocused",
      "command": "dotnet",
      "type": "shell",
      "args": [
        "build",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "../src/"
      }
    }
  ]
}
