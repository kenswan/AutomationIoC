{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build-SDK",
      "command": "dotnet",
      "type": "shell",
      "args": [
        "build",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src/sdk"
      }
    },
    {
      "label": "Build-Integration",
      "dependsOn": ["Build-SDK"],
      "command": "dotnet",
      "type": "shell",
      "args": [
        "build",
        "-c",
        "Debug",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/test/sdk"
      }
    }
  ]
}
