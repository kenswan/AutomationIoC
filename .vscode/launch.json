{
  "configurations": [
    {
      "name": "Integration",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build-Integration",
      "program": "pwsh",
      "args": [
        "-NoExit",
        "-NoProfile",
        "-Command",
        "Import-Module ${workspaceFolder}/test/sdk/bin/Debug/net6.0/PowerShellFocused.SDK.Test.dll",
        "-Verbose"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "PowerShell Interactive Session",
      "type": "PowerShell",
      "request": "launch",
      "cwd": "${workspaceRoot}"
    },
    {
      "name": "PowerShell Launch Startup",
      "type": "PowerShell",
      "request": "launch",
      "preLaunchTask": "Build-SDK",
      "script": "${workspaceFolder}\\test\\sdk\\Startup.ps1",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Cmdlets: Windows Powershell",
      "type": "clr",
      "request": "launch",
      "preLaunchTask": "Build-SDK",
      "program": "powershell",
      "args": [
        "-NoExit",
        "-NoProfile",
        "-Command",
        "Import-Module ${workspaceFolder}/src/powershell/bin/Debug/net6.0/PowerShellFocused.dll",
        "-Verbose"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ]
}
